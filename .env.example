# PixiePost production environment example
# Copy this file to .env and replace all placeholder values before deploying.
# Based on the official Postiz configuration reference:
# https://docs.postiz.com/configuration/reference

# ------------------------------------------------------------------------------
# Public URLs
# ------------------------------------------------------------------------------
# Public root URL for PixiePost.
MAIN_URL="https://pixiepost.pixiewire.com"
# Frontend URL served to browsers. For PixiePost this matches MAIN_URL.
FRONTEND_URL="https://pixiepost.pixiewire.com"
# Public backend API URL used by the frontend.
NEXT_PUBLIC_BACKEND_URL="https://pixiepost.pixiewire.com/api"
# Internal backend URL used inside the Postiz container.
BACKEND_INTERNAL_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# Core app settings
# ------------------------------------------------------------------------------
# REPLACE THIS with a long random secret before deployment.
JWT_SECRET="5QtFIXKje5QRgYZM/hv5tUS7yAVS7i7s7eY0ANNj/JgSL5FaAjqLyPyLWU4supTN"
# Postgres connection string for the Postiz app. Keep the hostname as postiz-postgres.
DATABASE_URL="postgresql://postiz-user:postiz-change-me@postiz-postgres:5432/postiz-db-local"
# Redis connection string for the Postiz app. Keep the hostname as postiz-redis.
REDIS_URL="redis://postiz-redis:6379"
# Temporal server address on the internal Docker network.
TEMPORAL_ADDRESS="temporal:7233"
# Required Postiz flag for the general product mode.
IS_GENERAL="true"
# Lock down self-signups in production.
DISABLE_REGISTRATION="true"
# Run scheduled jobs and automation.
RUN_CRON="true"
# Public API hourly rate limit.
API_LIMIT="30"
# Leave false unless you intentionally want to disable auth protections.
NOT_SECURED="false"

# ------------------------------------------------------------------------------
# Postgres service settings
# ------------------------------------------------------------------------------
# Database name for the postiz-postgres container.
POSTIZ_POSTGRES_DB="postiz-db-local"
# Database username for the postiz-postgres container.
POSTIZ_POSTGRES_USER="postiz-user"
# Database password for the postiz-postgres container.
POSTIZ_POSTGRES_PASSWORD="postiz-change-me"

# ------------------------------------------------------------------------------
# Storage settings
# ------------------------------------------------------------------------------
# Use local storage on the server unless moving uploads to R2 later.
STORAGE_PROVIDER="local"
# Local upload directory mounted into the app container.
UPLOAD_DIRECTORY="/uploads"
# Frontend upload directory path used by Postiz.
NEXT_PUBLIC_UPLOAD_DIRECTORY="/uploads"
# Optional public upload base URL if uploads move behind a CDN later.
NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY=""

# ------------------------------------------------------------------------------
# Optional email settings
# ------------------------------------------------------------------------------
# Resend API key for activation or transactional email.
RESEND_API_KEY=""
# From address used for outgoing email.
EMAIL_FROM_ADDRESS=""
# From name used for outgoing email.
EMAIL_FROM_NAME=""

# ------------------------------------------------------------------------------
# Optional Cloudflare R2 settings
# ------------------------------------------------------------------------------
# Fill these only if STORAGE_PROVIDER is switched to cloudflare.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKETNAME=""
CLOUDFLARE_BUCKET_URL=""
CLOUDFLARE_REGION="auto"

# ------------------------------------------------------------------------------
# Social media API credentials
# ------------------------------------------------------------------------------
# Add the credentials for each network you plan to connect in PixiePost.
X_API_KEY=""
X_API_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
BEEHIIVE_API_KEY=""
BEEHIIVE_PUBLICATION_ID=""
LISTMONK_DOMAIN=""
LISTMONK_USER=""
LISTMONK_API_KEY=""
LISTMONK_LIST_ID=""
THREADS_APP_ID=""
THREADS_APP_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
DRIBBBLE_CLIENT_ID=""
DRIBBBLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN_ID=""
SLACK_ID=""
SLACK_SECRET=""
SLACK_SIGNING_SECRET=""
MASTODON_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""

# ------------------------------------------------------------------------------
# Extension settings
# ------------------------------------------------------------------------------
# Used for cookie-based platform integrations if enabled later.
EXTENSION_ID=""

# ------------------------------------------------------------------------------
# AI and UI settings
# ------------------------------------------------------------------------------
# WILL BE REPLACED WITH ANTHROPIC
OPENAI_API_KEY=""
# Optional Discord support link for the UI footer/help surfaces.
NEXT_PUBLIC_DISCORD_SUPPORT=""
# Optional Polotno key if the editor feature is enabled.
NEXT_PUBLIC_POLOTNO=""

# ------------------------------------------------------------------------------
# Payment settings
# ------------------------------------------------------------------------------
# Platform fee percentage for Stripe-powered monetization features.
FEE_AMOUNT="0.05"
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""
STRIPE_SIGNING_KEY_CONNECT=""

# ------------------------------------------------------------------------------
# OAuth settings
# ------------------------------------------------------------------------------
# Generic OAuth provider display name shown in the UI.
NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME="Authentik"
# Generic OAuth provider logo URL shown in the UI.
NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL="https://raw.githubusercontent.com/walkxcode/dashboard-icons/master/png/authentik.png"
# Enable only if using a generic OAuth provider.
POSTIZ_GENERIC_OAUTH="false"
# Base URL for the OAuth provider.
POSTIZ_OAUTH_URL="https://auth.example.com"
# OAuth authorization endpoint.
POSTIZ_OAUTH_AUTH_URL="https://auth.example.com/application/o/authorize"
# OAuth token endpoint.
POSTIZ_OAUTH_TOKEN_URL="https://auth.example.com/application/o/token"
# OAuth user info endpoint.
POSTIZ_OAUTH_USERINFO_URL="https://authentik.example.com/application/o/userinfo"
# OAuth client ID.
POSTIZ_OAUTH_CLIENT_ID=""
# OAuth client secret.
POSTIZ_OAUTH_CLIENT_SECRET=""
# OAuth scopes requested during sign-in.
POSTIZ_OAUTH_SCOPE="openid profile email"

# ------------------------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------------------------
# Optional Sentry DSN for frontend error reporting.
NEXT_PUBLIC_SENTRY_DSN=""
# Enable Spotlight only when actively debugging.
SENTRY_SPOTLIGHT="0"

# ------------------------------------------------------------------------------
# Developer settings
# ------------------------------------------------------------------------------
# Leave false in production.
NX_ADD_PLUGINS="false"

# ------------------------------------------------------------------------------
# Optional short link providers
# ------------------------------------------------------------------------------
# Self-hosted Dub
DUB_TOKEN=""
DUB_API_ENDPOINT="https://api.dub.co"
DUB_SHORT_LINK_DOMAIN="dub.sh"
# Short.io
SHORT_IO_SECRET_KEY=""
# Kutt
KUTT_API_KEY=""
KUTT_API_ENDPOINT="https://kutt.it/api/v2"
KUTT_SHORT_LINK_DOMAIN="kutt.it"
# LinkDrip
LINK_DRIP_API_KEY=""
LINK_DRIP_API_ENDPOINT="https://api.linkdrip.com/v1/"
LINK_DRIP_SHORT_LINK_DOMAIN="dripl.ink"

# ------------------------------------------------------------------------------
# Temporal service settings
# ------------------------------------------------------------------------------
# Internal Temporal Postgres database name.
TEMPORAL_POSTGRES_DB="temporal"
# Internal Temporal Postgres username.
TEMPORAL_POSTGRES_USER="temporal"
# Internal Temporal Postgres password.
TEMPORAL_POSTGRES_PASSWORD="temporal-change-me"
# Temporal DB driver.
TEMPORAL_DB="postgres12"
# Temporal DB port.
TEMPORAL_DB_PORT="5432"
# Temporal Postgres hostname on the Docker network.
TEMPORAL_POSTGRES_SEEDS="temporal-postgresql"
# Path to the Temporal dynamic config file mounted into the container.
TEMPORAL_DYNAMIC_CONFIG_FILE_PATH="config/dynamicconfig/development-sql.yaml"
# Elasticsearch integration for Temporal visibility.
ENABLE_ES="true"
# Temporal Elasticsearch hostname on the Docker network.
ES_SEEDS="temporal-elasticsearch"
# Elasticsearch major version used by Temporal.
ES_VERSION="v7"
# Default Temporal namespace used by the app.
TEMPORAL_NAMESPACE="default"
# Allowed browser origin for Temporal UI, if you expose it later.
TEMPORAL_UI_CORS_ORIGINS="https://pixiepost.pixiewire.com"
